      "properties": {
        "mapId": { "type": "string" },
        "cycleNumber": { "type": "number" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "weeks": { "type": "array", "items": { "type": "object" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["mapId", "cycleNumber", "grade", "subject", "weeks", "createdBy"]
    },
    "WeeklyTeachingPlan": {
      "title": "Weekly Teaching Plan",
      "description": "Daily roadmap for a specific week.",
      "type": "object",
      "properties": {
        "cyclePlanId": { "type": "string" },
        "cycleNumber": { "type": "number" },
        "weekNumber": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "days": { "type": "array", "items": { "type": "object" } },
        "isReadyToTeach": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["cyclePlanId", "cycleNumber", "weekNumber", "grade", "subject", "days", "createdBy"]
    },
    "CoverageRecord": {
      "title": "Coverage Record",
      "description": "Tracks coverage of specific outcomes.",
      "type": "object",
      "properties": {
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "outcome": { "type": "string" },
        "status": { "type": "string" },
        "lastTaughtDate": { "type": "string", "format": "date" },
        "relatedLessonIds": { "type": "array", "items": { "type": "string" } },
        "cycleNumber": { "type": "number" },
        "createdBy": { "type": "string" }
      },
      "required": ["grade", "subject", "outcome", "status", "cycleNumber", "createdBy"]
    }
  },

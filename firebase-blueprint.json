      "properties": {
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "schoolYear": { "type": "string" },
        "cycles": { "type": "array", "items": { "type": "object" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["grade", "subject", "schoolYear", "cycles", "createdBy"]
    },
